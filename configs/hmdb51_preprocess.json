{
  "dataset": {
    "name": "ARID-mini-action-set",
    "root_dir": "/opt/data/private/EEC4200/ARID",
    "train_list": "/opt/data/private/EEC4200/arid_train.txt",
    "test_list": "/opt/data/private/EEC4200/arid_test.txt"
  },
  "preprocess": {
    "output_dir": "outputs/arid_preprocessed",
    "target_width": 224,
    "target_height": 224,
    "target_fps": 16.0,
    "num_frames": 32,
    "num_augmentations": 3,
    "augmentation_profile": "medium",
    "random_seed": 42,
    "jpeg_quality": 95,
    "low_light_enhancement": {
      "enabled": true,
      "gamma": 1.0,
      "clahe_clip_limit": 0.0,
      "clahe_grid_size": 8,
      "brightness_gain": 1.25,
      "contrast_gain": 1.05
    },
    "allowed_extensions": [
      ".avi",
      ".mp4",
      ".mov",
      ".mkv"
    ],
    "augmentations": {
      "horizontal_flip": {
        "enabled": true,
        "probability": 0.5
      },
      "brightness": {
        "enabled": true,
        "probability": 0.5,
        "min_factor": 0.9,
        "max_factor": 1.2
      },
      "contrast": {
        "enabled": true,
        "probability": 0.5,
        "min_factor": 0.9,
        "max_factor": 1.2
      },
      "saturation": {
        "enabled": true,
        "probability": 0.2,
        "min_factor": 0.9,
        "max_factor": 1.1
      },
      "hue_shift": {
        "enabled": true,
        "probability": 0.1,
        "max_shift": 4
      },
      "gaussian_blur": {
        "enabled": true,
        "probability": 0.1,
        "kernel_sizes": [
          3,
          5
        ]
      },
      "gaussian_noise": {
        "enabled": true,
        "probability": 0.05,
        "std_min": 2.0,
        "std_max": 5.0
      },
      "rotation": {
        "enabled": true,
        "probability": 0.1,
        "max_degrees": 5.0
      },
      "translation": {
        "enabled": true,
        "probability": 0.15,
        "max_ratio_x": 0.05,
        "max_ratio_y": 0.05
      },
      "zoom": {
        "enabled": true,
        "probability": 0.15,
        "min_scale": 0.95,
        "max_scale": 1.05
      },
      "random_crop": {
        "enabled": true,
        "probability": 0.2,
        "min_scale": 0.9,
        "max_scale": 0.98
      },
      "random_erasing": {
        "enabled": true,
        "probability": 0.05,
        "min_area_ratio": 0.01,
        "max_area_ratio": 0.04,
        "max_aspect_ratio": 1.5
      }
    }
  }
}
